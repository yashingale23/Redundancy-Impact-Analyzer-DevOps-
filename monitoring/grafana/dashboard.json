{
  "title": "SchemaInsight Dashboard",
  "panels": [
    {
      "title": "Total analyses performed",
      "type": "stat",
      "targets": [{ "expr": "schema_analyses_total" }],
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 }
    },
    {
      "title": "Last redundancy score",
      "type": "gauge",
      "targets": [{ "expr": "last_redundancy_score" }],
      "fieldConfig": { "defaults": { "min": 0, "max": 100 } },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 }
    },
    {
      "title": "API request duration (p95)",
      "type": "graph",
      "targets": [{ "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))" }],
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 6 }
    },
    {
      "title": "API errors total",
      "type": "stat",
      "targets": [{ "expr": "api_errors_total" }],
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 }
    }
  ]
}